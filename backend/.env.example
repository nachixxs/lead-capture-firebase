# Orígenes permitidos para CORS (separados por coma si hay más de uno).
# En producción: ALLOWED_ORIGINS=https://tu-dominio.vercel.app
# En desarrollo no hace falta setear esta variable — se permite localhost:* automáticamente.
ALLOWED_ORIGINS=

# ID del proyecto Firebase (ej: mi-proyecto-12345).
# Lo encontrás en Firebase Console → Configuración del proyecto → General.
FIREBASE_PROJECT_ID=
